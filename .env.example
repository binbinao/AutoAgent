# Copy to .env and fill in your values

# LLM provider API keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# AutoAgent settings
AUTOAGENT_DEFAULT_MODEL=gpt-4o-mini
AUTOAGENT_AUTO_APPROVE=false
AUTOAGENT_WORKSPACE=.
AUTOAGENT_MEMORY_PATH=.autoagent/memory.db
AUTOAGENT_PYTHON_TIMEOUT_SECONDS=10
