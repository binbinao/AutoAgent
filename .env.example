# Copy to .env and fill in your values
# LiteLLM reads provider keys and OPENAI_API_BASE from the environment (see src/autoagent/llm.py).

# -----------------------------------------------------------------------------
# Official providers
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# Third-party / OpenAI-compatible gateways (pick ONE block; comment out the rest)
# LiteLLM docs: https://docs.litellm.ai/docs/providers
# -----------------------------------------------------------------------------

# Generic OpenAI-compatible proxy (One API, New API, vLLM, etc.)
# OPENAI_API_BASE=https://your-gateway.example.com/v1
# OPENAI_API_KEY=sk-your-gateway-key
# AUTOAGENT_DEFAULT_MODEL=openai/gpt-4o-mini

# DeepSeek
# DEEPSEEK_API_KEY=sk-...
# AUTOAGENT_DEFAULT_MODEL=deepseek/deepseek-chat

# Moonshot (Kimi)
# MOONSHOT_API_KEY=sk-...
# AUTOAGENT_DEFAULT_MODEL=moonshot/moonshot-v1-8k

# SiliconFlow (OpenAI-compatible)
# OPENAI_API_BASE=https://api.siliconflow.cn/v1
# OPENAI_API_KEY=sk-...
# AUTOAGENT_DEFAULT_MODEL=openai/deepseek-ai/DeepSeek-V3

# OpenRouter
# OPENROUTER_API_KEY=sk-or-...
# AUTOAGENT_DEFAULT_MODEL=openrouter/openai/gpt-4o-mini

# Ollama (local)
# OPENAI_API_BASE=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# AUTOAGENT_DEFAULT_MODEL=openai/llama3.2

# Zhipu GLM
# ZAI_API_KEY=...
# AUTOAGENT_DEFAULT_MODEL=zai/glm-4-flash

# Alibaba DashScope (Qwen)
# DASHSCOPE_API_KEY=sk-...
# AUTOAGENT_DEFAULT_MODEL=dashscope/qwen-plus

# Optional: reduce LiteLLM noise (ERROR, INFO, DEBUG)
# LITELLM_LOG=WARNING

# -----------------------------------------------------------------------------
# AutoAgent settings (prefix AUTOAGENT_)
# -----------------------------------------------------------------------------
AUTOAGENT_DEFAULT_MODEL=gpt-4o-mini
AUTOAGENT_AUTO_APPROVE=false
AUTOAGENT_WORKSPACE=.
AUTOAGENT_MEMORY_PATH=.autoagent/memory.db
AUTOAGENT_PYTHON_TIMEOUT_SECONDS=10
